{
    "name": "@giro3d/giro3d",
    "version": "0.43.0-beta.9",
    "description": "A JS/WebGL framework for 3D geospatial data visualization",
    "keywords": [
        "front-end",
        "web",
        "framework",
        "webgl",
        "webgl2",
        "geography",
        "gis",
        "geospatial",
        "3d",
        "3D",
        "three",
        "three.js",
        "openlayers",
        "map",
        "layer",
        "visualization",
        "pointcloud",
        "3dtiles",
        "raster",
        "vector",
        "geojson",
        "geometry"
    ],
    "scripts": {
        "check-circular-dependencies": "madge -c --extensions ts ./src",
        "typecheck": "tsc --noEmit",
        "_check-folders": "node tasks/check-folders.mjs src test examples",
        "_generate-type-definitions": "tsc --declaration --declarationMap --emitDeclarationOnly --project tsconfig.package.json",
        "_inline-workers": "node tasks/inline-workers.mjs build/giro3d",
        "_transpile": "shx rm -rf build/giro3d && shx mkdir -p build/giro3d && shx cp -rf src build/giro3d/src && cross-env BABEL_DISABLE_CACHE=1 babel --extensions .ts,.js src --out-dir build/giro3d",
        "build-apidoc": "node tasks/build-apidoc.mjs",
        "build-examples:dev": "npm run build && node tasks/build-examples.mjs --mode=development",
        "build-examples": "npm run build && node tasks/build-examples.mjs",
        "build-tutorials": "npm run build-examples && node tasks/build-tutorials.mjs",
        "build-static-site": "node tasks/build-static-site.mjs",
        "build-site": "npm run build && node tasks/build-site.mjs --build-latest",
        "build": "npm run _transpile && npm run _generate-type-definitions",
        "build-package": "npm run build && npm run _inline-workers && node tasks/prepare-package.mjs",
        "commit": "npx git-cz",
        "format-eslint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"examples/**/*.js\" --fix",
        "format-prettier": "prettier --write .",
        "format-markdownlint": "markdownlint . --fix --ignore-path .gitignore",
        "format": "npm run format-eslint && npm run format-prettier && npm run format-markdownlint",
        "docker": "docker build . -t giro3d:local && docker run --rm -p 8080:8080 giro3d:local",
        "lint-prettier": "prettier --check .",
        "lint-commit": "commitlint -x @commitlint/config-conventional --from=origin/HEAD --to=HEAD",
        "lint-doc": "node tasks/build-apidoc.mjs --lint-only",
        "lint-eslint": "npm run _transpile && eslint \"src/**/*.ts\" \"test/**/*.ts\" \"examples/**/*.js\"",
        "lint-markdownlint": "markdownlint . --ignore-path .gitignore",
        "lint": "npm run check-circular-dependencies && npm run typecheck && npm run lint-doc && npm run _check-folders && npm run lint-eslint && npm run lint-prettier && npm run lint-markdownlint",
        "make-package": "npm run build-package && npm pack build/giro3d/",
        "prepack": "npm run build-package",
        "serve-apidoc": "node tasks/build-apidoc.mjs --watch",
        "serve-examples": "npm run build && node tasks/build-examples.mjs --watch",
        "serve-tutorials": "npm run build-examples && node tasks/build-tutorials.mjs --watch",
        "serve-static-site": "node tasks/build-static-site.mjs --watch",
        "serve-site": "npm run build && node tasks/build-site.mjs --build-latest --watch",
        "start": "npm run build && concurrently \"node tasks/build-examples.mjs $EXAMPLE --watch --mode=development\" \"tsc --declaration --declarationMap --emitDeclarationOnly --watch\"",
        "test-unit": "jest test/unit",
        "check-coverage": "jest --coverage",
        "test-with-coverage": "npm run check-coverage test/unit",
        "test": "npm run lint -- --max-warnings=0 && npm run build && npm run test-with-coverage",
        "watch": "node observer.mjs ./src ./build/giro3d",
        "prepare": "husky"
    },
    "repository": {
        "type": "git",
        "url": "git+https://gitlab.com/giro3d/giro3d.git"
    },
    "license": "MIT",
    "bugs": {
        "url": "https://gitlab.com/giro3d/giro3d/-/issues"
    },
    "homepage": "https://giro3d.org/",
    "browserslist": [
        ">0.5%",
        "not dead",
        "not op_mini all",
        "Firefox ESR"
    ],
    "dependencies": {
        "3d-tiles-renderer": "^0.4.3",
        "chart.js": "^3.9.1",
        "copc": "^0.0.8",
        "earcut": "^2.2.4",
        "geotiff": "^2.1.0",
        "lil-gui": "^0.17.0",
        "lru-cache": "^10.0.1",
        "three-mesh-bvh": "^0.7.4"
    },
    "peerDependencies": {
        "ol": "9",
        "proj4": "^2.9.0",
        "three": "^0.170.0"
    },
    "devDependencies": {
        "@babel/cli": "^7.25.7",
        "@babel/core": "^7.25.8",
        "@babel/plugin-transform-runtime": "^7.25.7",
        "@babel/preset-env": "^7.25.8",
        "@babel/preset-typescript": "^7.25.7",
        "@babel/register": "^7.25.7",
        "@commitlint/cli": "19.5.0",
        "@commitlint/config-conventional": "19.5.0",
        "@turf/turf": "^7.1.0",
        "@types/earcut": "^2.1.4",
        "@types/emscripten": "^1.39.13",
        "@types/geojson": "^7946.0.14",
        "@types/jest": "^29.5.13",
        "@types/proj4": "^2.5.5",
        "@types/three": "^0.170.0",
        "@typescript-eslint/eslint-plugin": "8.9.0",
        "@typescript-eslint/parser": "8.9.0",
        "babel-jest": "^29.7.0",
        "babel-loader": "9.2.1",
        "babel-plugin-inline-import": "^3.0.0",
        "babel-plugin-minify-dead-code-elimination": "^0.5.2",
        "babel-plugin-minify-replace": "^0.5.0",
        "babel-plugin-transform-import-meta": "^2.2.1",
        "babel-polyfill": "^6.26.0",
        "bootstrap": "^5.3.3",
        "bootstrap-icons": "^1.11.3",
        "browserslist": "^4.24.0",
        "camera-controls": "^2.9.0",
        "chalk": "^5.3.0",
        "chokidar": "4.0.1",
        "circular-dependency-plugin": "^5.2.2",
        "colormap": "^2.3.2",
        "commander": "^12.1.0",
        "concurrently": "9.0.1",
        "copy-webpack-plugin": "12.0.2",
        "cross-env": "7.0.3",
        "docco-next": "^0.9.14",
        "es-main": "^1.3.0",
        "esbuild": "^0.25.1",
        "eslint": "9.12.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-import-resolver-alias": "^1.1.2",
        "eslint-import-resolver-typescript": "^3.6.3",
        "eslint-import-resolver-webpack": "^0.13.9",
        "eslint-plugin-compat": "6.0.1",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-jest": "28.8.3",
        "eslint-plugin-prettier": "^5.2.1",
        "eslint-plugin-tsdoc": "^0.3.0",
        "eslint-webpack-plugin": "4.2.0",
        "front-matter": "^4.0.2",
        "fs": "^0.0.2",
        "fs-extra": "^11.2.0",
        "function-curve-editor": "^1.0.16",
        "glob": "11.0.0",
        "globals": "^15.11.0",
        "husky": "^9.1.6",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "29.7.0",
        "jsdom": "25.0.1",
        "madge": "^8.0.0",
        "markdownlint": "^0.35.0",
        "markdownlint-cli": "^0.42.0",
        "path": "^0.12.7",
        "prettier": "^3.3.3",
        "prettier-eslint": "^16.3.0",
        "prettier-plugin-ejs": "^1.0.3",
        "prettier-plugin-organize-imports": "^4.1.0",
        "process": "^0.11.10",
        "proj4": "^2.12.1",
        "sass": "1.70.0",
        "shiki": "1.22.0",
        "shx": "^0.3.4",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "typedoc": "^0.26.10",
        "typescript": "~5.5.4",
        "util": "^0.12.5",
        "validate-branch-name": "^1.3.1",
        "webgl-lint": "^1.11.3",
        "webpack": "^5.95.0",
        "webpack-cli": "5.1.4",
        "webpack-dev-server": "5.1.0",
        "webpack-glsl-loader": "^1.0.1"
    },
    "lint-staged": {
        "**/*.{ts,vue,js,jsx,cjs,mjs}": [
            "eslint",
            "prettier"
        ],
        "**/*.{json,jsonc,css,scss,ejs}": [
            "prettier"
        ],
        "**/*.md": [
            "markdownlint",
            "prettier"
        ]
    },
    "config": {
        "commitizen": {
            "path": "@commitlint/cz-commitlint",
            "name": "cz_conventional_commits",
            "tag_format": "v$version"
        }
    }
}
