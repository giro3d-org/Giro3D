{
    // This config file is used mainly to have remapped import paths in the example working with VSCode.

    "extends": "../tsconfig.json",
    "include": ["./**/*"],
    "exclude": ["../node_modules/**/*"],
    "compilerOptions": {
        "paths": {
            "@giro3d/giro3d/*": ["../build/giro3d/*"]
        },
        "typeRoots": ["../build/giro3d/*"],
        "allowJs": true,
        "checkJs": true,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "strictNullChecks": false,
        "target": "es2021",
        "lib": ["DOM", "DOM.Iterable", "ES2021"]
    }
}
