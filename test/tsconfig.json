{
    // This config file is used to support remapped import paths in the tests.

    "extends": "../tsconfig.json",
    "include": ["./**/*"],
    "exclude": ["node_modules/**/*"],
    "compilerOptions": {
        "paths": {
            "@giro3d/giro3d/*": ["../src/*"]
        },
        "allowJs": true
    }
}
